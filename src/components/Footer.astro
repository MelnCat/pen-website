---
import { Image } from "astro:assets";

import Icon from "../assets/icons/icon-placeholder.svg"
---

<footer>
	<article>
		<section class="pen">
			<div class="gray"><div >
				<Image src={Icon} alt="" class="image"/>
			</div> <span>Pacific Education Network</span></div>
			<div>We help by providing better access to education.</div>
		</section>
		<section class="contact">
			<div>
				Contact: <span data-obfuscation="0">yangyicheng009@gmail.com</span> • Vancouver, BC
			</div>
			<div>Follow: Instagram • TikTok • YouTube</div>
		</section>
	</article>
	<section class="bottom">
		<div>© 2026 Pacific Education Network (Society). All rights reserved.</div>
		<div>Privacy Policy</div>
	</section>
</footer>

<style>
    .contact {
        font-size: var(--step-0);
    }
    footer {
    background-color: #000000;
    border-top: 2px solid #545454;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-l) var(--space-m);
}
.pen {
    font-style: italic;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    .image {
        width: 2em;
        height: 2em;
        background-color: red;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .gray {
        color: #969696;
        display: flex;
        align-items: center;
        gap: var(--space-3xs);
        span {
            white-space: nowrap;
        }
    }
}
article {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    width: 100%;
    max-width: 70rem;
    padding-bottom: var(--space-l);
}
.bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    width: 100%;
    max-width: 70rem;
    border-top: 2px solid #545454;
    padding-top: var(--space-s);
    font-size: var(--step--1);
}

@media (min-width: 640px) {
    article {
        flex-direction: row;
        justify-content: space-between;
        .contact {
            text-align: right;
        }
    }
    .bottom {
        flex-direction: row;
        justify-content: space-between;
    }
}
</style>
